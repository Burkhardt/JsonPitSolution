@startuml RAIkeep-Package-Dependencies
title RAIkeep Package Dependencies

top to bottom direction

skinparam backgroundColor white
skinparam shadowing false
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam ArrowColor #4b5563
skinparam PackageBorderColor #1f2937
skinparam PackageFontColor #111827
skinparam ClassBorderColor #6b7280
skinparam ClassBackgroundColor #f9fafb
skinparam RectangleBorderColor #6b7280
skinparam RectangleBackgroundColor #f9fafb
skinparam NoteBackgroundColor #fff7d6
skinparam NoteBorderColor #d4b106

package "OsLib" as P_OsLib {
	rectangle "Ⓒ Os\nⒸ RaiFile\nⒸ RaiPath\nⒸ RaiSystem\nⒸ TextFile\nⒸ CsvFile\nⒸ TmpFile\nⒸ CanonicalFile\nⒸ CanonicalPath\nⒸ PathConventionType" as M_OsLib
}

package "OsLib.Tests" <<tests>> as T_OsLib {
	rectangle "Ⓣ CloudStorageAgreementTests\nⓉ CloudStorageDiscoveryTests\nⓉ PathConventionsTests\nⓉ TmpFileTests" as M_T_OsLib
}

package "RaiUtils" as P_RaiUtils {
	rectangle "Ⓒ Email\nⒸ JsonConversionExtensions\nⒸ ParameterDictionary\nⒸ RandomExtensions\nⒸ SearchExpression" as M_RaiUtils
}

package "RaiUtils.Tests" <<tests>> as T_RaiUtils {
	rectangle "Ⓣ EmailTests\nⓉ JsonConversionExtensionTests\nⓉ ParameterDictionaryTests\nⓉ RandomExtensionsTests\nⓉ SearchExpressionTests" as M_T_RaiUtils
}

package "JsonPit" as P_JsonPit {
	rectangle "Ⓒ Item\nⒸ ItemsBase\nⒸ JsonPitBase\nⒸ Pit\nⒸ PitItem\nⒸ PitItems\nⒸ MasterFlagFile\nⒸ ProcessFlagFile\nⒸ TimestampedValue" as M_JsonPit
}

package "JsonPit.Tests" <<tests>> as T_JsonPit {
	rectangle "Ⓣ UnitTests\nⓉ PitAddConcurrencyTests\nⓉ PitItemSetPropertyChangeDetectionTests" as M_T_JsonPit
}

package "RaiImage" as P_RaiImage {
	rectangle "Ⓒ CamelCase\nⒸ ColorInfo\nⒸ Dye\nⒸ ImageFile\nⒸ ImageTreeFile\nⒸ ImageMagick\nⒸ ImageUrl\nⒸ Src\nⒸ Tmp\nⒸ TwoSizes" as M_RaiImage
}

package "RaiImage.Tests" <<tests>> as T_RaiImage {
	rectangle "Ⓣ ImageFileTests\nⓉ ImageTreeFileTests\nⓉ ImageMagickTests" as M_T_RaiImage
}

' 2 columns x 4 rows: package on the left, matching test package on the right.
P_OsLib -[norank]right-> T_OsLib
P_RaiUtils -[norank]right-> T_RaiUtils
P_JsonPit -[norank]right-> T_JsonPit
P_RaiImage -[norank]right-> T_RaiImage

P_OsLib -[norank]down-> P_RaiUtils
P_RaiUtils -[norank]down-> P_JsonPit
P_JsonPit -[norank]down-> P_RaiImage

P_JsonPit ..[norank]> P_OsLib : ProjectReference
P_JsonPit ..[norank]> P_RaiUtils : ProjectReference
P_RaiImage ..[norank]> P_OsLib : ProjectReference
P_RaiImage ..[norank]> P_RaiUtils : ProjectReference

T_OsLib ..> P_OsLib : tests
T_RaiUtils ..> P_RaiUtils : tests
T_JsonPit ..> P_JsonPit : tests
T_RaiImage ..> P_RaiImage : tests

note bottom of P_OsLib
	Foundation library for OS, paths,
	files, temp files, and cloud-root discovery.
end note

note bottom of P_RaiUtils
	Utility library with JSON conversion,
	randomization, parameter, email,
	and search helpers.
end note

note bottom of P_JsonPit
	JsonPit depends directly on OsLib and RaiUtils.
	Its tests also exercise those dependencies.
end note

note bottom of P_RaiImage
	RaiImage references OsLib and RaiUtils when
	local projects are available, and can fall back
	to NuGet package references otherwise.
end note

legend bottom
	Solid package contents show representative classes.
	Dashed arrows show project-level dependencies.
	<<tests>> packages represent test projects in RAIkeep.slnx.
	Hidden right-links define the two columns.
	Hidden down-links define the four rows.
endlegend

@enduml